# Live database — never commit this, it contains real user data
database.sqlite
database.db

# User session files (keep the directory and its .htaccess, ignore session data)
sessions/sess_*

# Environment secrets
.env
.env.local

# Uploaded files (keep on server, don't commit)
uploads/

# Logs
*.log
php_errors.log

# Diagnostic/temp scripts
check_setup.php

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
